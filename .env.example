# ─────────────────────────────────────────────────────────────────────────────
# Cognitive Voice AI Agent — environment template.
#
# All five hosted services below have a free tier that's enough for the demo:
#   • LiveKit Cloud           https://cloud.livekit.io          (free dev project)
#   • Neo4j Aura              https://neo4j.com/cloud/aura/     (AuraDB Free)
#   • OpenAI                  https://platform.openai.com       (paid; ~$0.005/call)
#   • ElevenLabs              https://elevenlabs.io             (free 10k chars/mo)
#   • Deepgram                https://console.deepgram.com      (free $200 credit)
#
# Copy this to `.env` and fill in. Anything left blank degrades gracefully (the worker
# logs a clear error and exits cleanly rather than crashing mid-call).
# ─────────────────────────────────────────────────────────────────────────────

# ── LiveKit Cloud ───────────────────────────────────────────────────────────
# Get from https://cloud.livekit.io → your project → Settings → Keys.
# (For self-hosted: LIVEKIT_URL is ws:// or wss:// and you mint your own keys.)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Neo4j Aura ──────────────────────────────────────────────────────────────
# Sign up → create a Free AuraDB instance → "Download credentials" → use the
# `neo4j+s://` connection URI (TLS) it gives you. Our async driver handles this URI
# scheme natively — no code changes needed when moving from local Docker to Aura.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=keep-this-secret

# ── OpenAI (LLM for live replies + post-call fact extraction) ───────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o
LEXICAL_MODEL=gpt-4o-mini

# ── ElevenLabs (TTS + Dynamic Prosody) ──────────────────────────────────────
# Use any two voices from your voice library. Frustrated/angry callers route to
# `ELEVENLABS_CALM_VOICE_ID` with stability=0.95; everyone else gets the default.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # "Rachel" — neutral
ELEVENLABS_CALM_VOICE_ID=EXAVITQu4vr4xnSDxMaL      # "Bella" — calm

# ── Deepgram (STT) ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# ── Post-call acoustic engine ───────────────────────────────────────────────
# auto    = rich SenseVoice+openSMILE if `pip install -r requirements-rich.txt`,
#           else the librosa-only heuristic.
# rich    = force rich (logs warning + falls back if heavy deps missing).
# librosa = always use librosa-only (lightest path; what the demo defaults to).
AFFECT_EXTRACTOR=librosa

# ── Adaptive Verbosity tuning ───────────────────────────────────────────────
# Number of user-on-agent interruptions before we flag conversation_style=impatient.
IMPATIENCE_THRESHOLD=2

# ── Base system prompt (pre-call decorates with prosody/empathy/verbosity) ──
BASE_SYSTEM_PROMPT="You are a warm, concise voice assistant on a phone call. Keep replies to one or two sentences. Never use markdown or emoji."

# ── Web demo (web/server.py) ────────────────────────────────────────────────
# WEB_HOST defaults to 0.0.0.0 so it works behind a hosting platform's load balancer.
# On Render/Railway/Fly, the platform injects a PORT env var — uvicorn picks it up if you
# start with `uvicorn web.server:app --host 0.0.0.0 --port $PORT`.
WEB_HOST=0.0.0.0
WEB_PORT=8000
