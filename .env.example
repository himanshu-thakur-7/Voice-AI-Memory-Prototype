# LiveKit Cognitive Memory & Affective Intelligence Agent — environment template.
# Copy to .env and fill in. Anything you leave blank degrades gracefully (mock providers
# or in-memory fallbacks) so the worker still boots for local development.

# ── LiveKit (UDP transport, VAD, STT/TTS streaming) ──────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret123456789012345678901234

# ── OpenAI (LLM for live replies + post-call fact/sarcasm extraction) ────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
LEXICAL_MODEL=gpt-4o-mini      # cheaper model for the post-call extraction pass

# ── ElevenLabs (TTS + Dynamic Prosody) ───────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # "Rachel" — neutral default
ELEVENLABS_CALM_VOICE_ID=EXAVITQu4vr4xnSDxMaL      # "Bella" — calm voice for frustrated callers

# ── Deepgram (STT) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# ── Neo4j (cognitive graph) ──────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cognitive-dev-password

# ── Post-call acoustic engine ────────────────────────────────────────────────
# auto   = rich SenseVoice+openSMILE if installed (pip install -r requirements-rich.txt),
#          else the librosa-only heuristic fallback.
# rich   = force rich (warns + falls back if deps missing).
# librosa = always use librosa-only.
AFFECT_EXTRACTOR=auto

# ── Adaptive Verbosity tuning ────────────────────────────────────────────────
# Number of user interruptions during a call before we flag conversation_style=impatient.
IMPATIENCE_THRESHOLD=2

# ── Base prompt the agent starts from before prosody/empathy adjustments. ────
BASE_SYSTEM_PROMPT="You are a warm, concise voice assistant on a phone call. Keep replies to one or two sentences. Never use markdown or emoji."
