# ─────────────────────────────────────────────────────────────────────────────
# Voice AI Prototype — environment template. Copy to `.env` and fill in.
# Nothing here is loaded unless present; the repo RUNS with only the Deepgram +
# OpenAI + ElevenLabs keys set (Ringg/FalkorDB are optional upgrades).
# ─────────────────────────────────────────────────────────────────────────────

# ── Engine selection ─────────────────────────────────────────────────────────
# cascade  = Twilio → STT → GPT-4o → ElevenLabs  (per-stage control, ~800ms p50)
# realtime = OpenAI Realtime API speech-to-speech (sub-second, fewer knobs)
ENGINE=cascade

# ── STT provider (cascade engine only) ───────────────────────────────────────
# openai | deepgram | elevenlabs | ringg
# Default 'openai' reuses OPENAI_API_KEY below — no separate STT account needed.
STT_PROVIDER=openai

# ── Public host the Go scheduler tells Twilio to stream to ────────────────────
# In local dev this is your ngrok host, e.g. wss://abc123.ngrok.app/media
MEDIA_WS_URL=wss://localhost:8080/media

# ── Telephony: Twilio ────────────────────────────────────────────────────────
TWILIO_AUTH_TOKEN=                 # used to validate X-Twilio-Signature on the webhook
TWILIO_ACCOUNT_SID=

# ── OpenAI: LLM + default STT (one key powers both) ──────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o                       # honored per spec; configurable — see docs/latency-budget.md
OPENAI_REALTIME_MODEL=gpt-realtime     # used by the realtime engine
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe  # default STT (realtime transcription); reuses OPENAI_API_KEY
OPENAI_LEXICAL_MODEL=gpt-4o-mini       # post-call tone/contradiction analysis (paralinguistics)

# ── Post-call affective extraction ───────────────────────────────────────────
# auto = rich SenseVoice+openSMILE engine if installed (pip install '.[paralinguistics]'),
#        else the dependency-free heuristic. Also: rich | heuristic.
AFFECT_EXTRACTOR=auto

# ── STT: Ringg Parrot (default-of-record; prod access via sales@ringg.ai) ─────
RINGG_API_KEY=
RINGG_STT_MODEL=parrot-stt-v1

# ── STT: Deepgram (runnable fallback) ────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# ── TTS: ElevenLabs ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=               # an IVC/default voice is lower-latency than a PVC
ELEVENLABS_MODEL=eleven_flash_v2_5

# ── Memory stores ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://voiceai:voiceai@postgres:5432/voiceai   # pgvector
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
REDIS_URL=redis://redis:6379/0
MEM0_GRAPH_ENABLED=false           # true → use FalkorDB graph (Mem0g); false → pgvector only

# ── Service wiring ───────────────────────────────────────────────────────────
GRPC_BACKEND_ADDR=backend:50051    # Go dials this; Python serves it
HTTP_LISTEN_ADDR=:8080             # Go scheduler webhook
BACKEND_LISTEN_ADDR=0.0.0.0:8000   # Python FastAPI
LOG_LEVEL=info
MAX_CONCURRENT_CALLS=200           # global fair-share ceiling in the Go scheduler
